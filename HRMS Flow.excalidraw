    {
      "id": "rS6K-sqMsP8g2B1RAXKlH",
      "type": "text",
      "x": 209.1635430880549,
      "y": 10246.52770673189,
      "width": 223.89732498322394,
      "height": 70.5831421555805,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 40,
      "groupIds": [],
      "frameId": null,
      "index": "bnI",
      "roundness": null,
      "seed": 1458131331,
      "version": 280,
      "versionNonce": 230529027,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1760505142370,
      "link": null,
      "locked": false,
      "text": "Enable this to automatically\ncalculate and deduct provident\nfund contributions from both\nemployer and employee.",
      "fontSize": 14.116628431116101,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Enable this to automatically calculate and deduct provident fund contributions from both employer and employee.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "ZAK5mewHWjXxfY6IjTFL8",
      "type": "text",
      "x": 525.0969205733787,
      "y": 10242.422016288456,
      "width": 259.42001956661574,
      "height": 88.22892769447563,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 40,
      "groupIds": [],
      "frameId": null,
      "index": "bnJ",
      "roundness": null,
      "seed": 1097476387,
      "version": 306,
      "versionNonce": 1753882029,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1760505142370,
      "link": null,
      "locked": false,
      "text": "Enable this if your organization is\nregistered under ESIC. This will\ndeduct and contribute the ESIC\namount for both employee and\nemployer.",
      "fontSize": 14.116628431116101,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Enable this if your organization is registered under ESIC. This will deduct and contribute the ESIC amount for both employee and employer.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "R32VsOcE19ShRzSR0ftrt",
      "type": "text",
      "x": 201.46041789320816,
      "y": 10392.59726145228,
      "width": 208.3782082698089,
      "height": 70.5831421555805,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 40,
      "groupIds": [],
      "frameId": null,
      "index": "bnK",
      "roundness": null,
      "seed": 1093602499,
      "version": 291,
      "versionNonce": 1391566755,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1760505142370,
      "link": null,
      "locked": false,
      "text": "Turn this on to deduct\nprofessional tax based on\nemployee income, as per your\nstate government.",
      "fontSize": 14.116628431116101,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Turn this on to deduct professional tax based on employee income, as per your state government.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "gTK62oZ7GvSPdZwRLsSuS",
      "type": "text",
      "x": 530.4376930597253,
      "y": 10396.587584949262,
      "width": 263.7022798010124,
      "height": 70.5831421555805,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 40,
      "groupIds": [],
      "frameId": null,
      "index": "bnL",
      "roundness": null,
      "seed": 701922403,
      "version": 272,
      "versionNonce": 1177804813,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1760505142370,
      "link": null,
      "locked": false,
      "text": "Enable this to deduct a fixed\ncontribution toward the Labour\nWelfare Fund for both employee and\nemployer.",
      "fontSize": 14.116628431116101,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Enable this to deduct a fixed contribution toward the Labour Welfare Fund for both employee and employer.",
      "autoResize": false,
      "lineHeight": 1.25
    },
