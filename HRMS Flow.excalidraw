    },
    {
      "id": "hTjKsCA_A_PWCP6rXQtZ0",
      "type": "text",
      "x": 773.2625350428084,
      "y": 3005.161559772023,
      "width": 744.7593383789062,
      "height": 105,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fab005",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "buq",
      "roundness": null,
      "seed": 1076500719,
      "version": 501,
      "versionNonce": 964101892,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1762496555084,
      "link": null,
      "locked": false,
      "text": "Employees can mark their attendance using the Check\nIn/Check Out systray, and users can view their\nattendance records through the Attendance module. ",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Employees can mark their attendance using the Check In/Check Out systray, and users can view their attendance records through the Attendance module. ",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "yvfYfz2cEAzgWdTj9P30x",
      "type": "text",
      "x": 2206.3153287796727,
      "y": 11848.381942929427,
      "width": 144.54428100585938,
      "height": 20,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 70,
      "groupIds": [],
      "frameId": null,
      "index": "bur",
      "roundness": null,
      "seed": 452075603,
      "version": 3,
      "versionNonce": 30304147,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1761558559060,
      "link": null,
      "locked": false,
      "text": "\"license\": \"LGPL-3\",",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"license\": \"LGPL-3\",",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "JJLlZgkUEAow-c_iBfTbV",
      "type": "text",
      "x": -2117.195891114825,
      "y": 4683.297910944943,
      "width": 765.7992553710938,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fab005",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 80,
      "groupIds": [],
      "frameId": null,
      "index": "bus",
      "roundness": null,
      "seed": 414676705,
      "version": 838,
      "versionNonce": 500952380,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1762497380215,
      "link": null,
      "locked": false,
      "text": "On the Attendance page, users should see a day-wise attendance of\nthemselves by default for ongoing month, displaying details based on their\nworking time, including breaks. \n\nFor Admins/Time off officers: They can see attendance of aff the employees\npresent on the current day.\n\nAttendance data serves as the basis for payslip generation.\n\nThe system should use the generated attendance records to determine the\ntotal number of payable days for each employee.\n\nAny unpaid leave or missing attendance days should automatically reduce the\nnumber of payable days during payslip computation",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "On the Attendance page, users should see a day-wise attendance of themselves by default for ongoing month, displaying details based on their working time, including breaks. \n\nFor Admins/Time off officers: They can see attendance of aff the employees\npresent on the current day.\n\nAttendance data serves as the basis for payslip generation.\n\nThe system should use the generated attendance records to determine the total number of payable days for each employee.\n\nAny unpaid leave or missing attendance days should automatically reduce the number of payable days during payslip computation",
      "autoResize": false,
      "lineHeight": 1.25
    },
