    {
      "id": "cdG8AOBrDyn9c_ve5OV-r",
      "type": "text",
      "x": -7321.081061168345,
      "y": 8675.735265556592,
      "width": 223.89732498322394,
      "height": 70.5831421555805,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 40,
      "groupIds": [],
      "frameId": null,
      "index": "bmd",
      "roundness": null,
      "seed": 814907400,
      "version": 395,
      "versionNonce": 694564302,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1762434793863,
      "link": null,
      "locked": false,
      "text": "Enable this to automatically\ncalculate and deduct provident\nfund contributions from both\nemployer and employee.",
      "fontSize": 14.116628431116101,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Enable this to automatically calculate and deduct provident fund contributions from both employer and employee.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "8aBhV7DrE_3SALd9SrzIw",
      "type": "text",
      "x": -7005.147683683021,
      "y": 8671.629575113158,
      "width": 259.42001956661574,
      "height": 88.22892769447563,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 40,
      "groupIds": [],
      "frameId": null,
      "index": "bme",
      "roundness": null,
      "seed": 1266617976,
      "version": 421,
      "versionNonce": 798709266,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1762434793863,
      "link": null,
      "locked": false,
      "text": "Enable this if your organization is\nregistered under ESIC. This will\ndeduct and contribute the ESIC\namount for both employee and\nemployer.",
      "fontSize": 14.116628431116101,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Enable this if your organization is registered under ESIC. This will deduct and contribute the ESIC amount for both employee and employer.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "TXZZDcIlXNhlaWMEwKX8S",
      "type": "text",
      "x": -7328.784186363191,
      "y": 8821.804820276982,
      "width": 208.3782082698089,
      "height": 70.5831421555805,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 40,
      "groupIds": [],
      "frameId": null,
      "index": "bmf",
      "roundness": null,
      "seed": 1169813768,
      "version": 406,
      "versionNonce": 721046542,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1762434793863,
      "link": null,
      "locked": false,
      "text": "Turn this on to deduct\nprofessional tax based on\nemployee income, as per your\nstate government.",
      "fontSize": 14.116628431116101,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Turn this on to deduct professional tax based on employee income, as per your state government.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "1-W15soIV8bJdAr_L-YoX",
      "type": "text",
      "x": -6999.806911196674,
      "y": 8825.795143773963,
      "width": 263.7022798010124,
      "height": 70.5831421555805,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 40,
      "groupIds": [],
      "frameId": null,
      "index": "bmg",
      "roundness": null,
      "seed": 1000735240,
      "version": 387,
      "versionNonce": 1370145746,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1762434793863,
      "link": null,
      "locked": false,
      "text": "Enable this to deduct a fixed\ncontribution toward the Labour\nWelfare Fund for both employee and\nemployer.",
      "fontSize": 14.116628431116101,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Enable this to deduct a fixed contribution toward the Labour Welfare Fund for both employee and employer.",
      "autoResize": false,
      "lineHeight": 1.25
    },
